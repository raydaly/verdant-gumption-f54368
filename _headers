/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: no-store, no-cache, must-revalidate
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
# Filenames under /src are not content-hashed, so they must never be treated
# as immutable — the service worker handles caching for offline use instead.
/src/*
  Cache-Control: no-cache
